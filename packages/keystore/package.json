{
  "name": "@authmesh/keystore",
  "version": "0.6.0",
  "description": "Secure Enclave, macOS Keychain, and TPM 2.0 key storage for amesh",
  "type": "module",
  "license": "MIT",
  "author": "Yair Etzion",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameshdev/amesh.git",
    "directory": "packages/keystore"
  },
  "homepage": "https://github.com/ameshdev/amesh",
  "keywords": [
    "authentication",
    "keystore",
    "secure-enclave",
    "tpm",
