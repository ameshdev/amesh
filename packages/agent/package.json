{
  "name": "@authmesh/agent",
  "version": "0.2.0",
  "description": "amesh agent daemon + CLI — remote shell target with device-bound identity",
  "type": "module",
  "license": "MIT",
  "author": "Yair Etzion",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameshdev/amesh.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/ameshdev/amesh",
  "keywords": [
    "authentication",
    "agent",
    "remote-shell",
    "ssh-alternative",
    "device-identity",
    "pty",
    "daemon"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "amesh-agent": "./dist/index.js"
  },
  "oclif": {
    "commands": "./dist/commands",
    "bin": "amesh-agent"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "bun test src/__tests__/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@authmesh/core": "workspace:*",
    "@authmesh/keystore": "workspace:*",
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "2.0.1",
    "@noble/hashes": "2.0.1",
    "@oclif/core": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
