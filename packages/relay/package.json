{
  "name": "@authmesh/relay",
  "version": "0.2.0",
  "description": "WebSocket relay server for amesh device pairing handshakes",
  "type": "module",
  "license": "MIT",
  "author": "Yair Etzion",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameshdev/amesh.git",
    "directory": "packages/relay"
  },
  "homepage": "https://github.com/ameshdev/amesh",
  "keywords": [
    "authentication",
    "relay",
    "websocket",
    "handshake",
    "bun",
    "pairing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "amesh-relay": "./dist/start.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "test": "bun test src/__tests__/",
    "test:watch": "bun test --watch src/__tests__/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "bun dist/start.js"
  },
  "dependencies": {
    "@authmesh/core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@noble/curves": "2.0.1",
    "@noble/hashes": "2.0.1",
    "@types/bun": "^1.3.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
